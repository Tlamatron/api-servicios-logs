<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Info"
      internalLogFile="${basedir}/Log/nlog-internal.log">

  <targets>
    <!-- Logs por aplicación con 20MB de límite -->
    <target xsi:type="File"
            name="appLog"
            fileName="${basedir}/Log/Log_${logger:shortName=true}.log"
            layout="${longdate} | ${level:uppercase=true} | ${message}"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            archiveAboveSize="20971520"
            archiveNumbering="Date"
            maxArchiveFiles="10" />

    <!-- Auditoría central con 1GB de límite -->
    <target xsi:type="File"
            name="auditLog"
            fileName="${basedir}/Log/auditoria.log"
            layout="${longdate} | ${level:uppercase=true} | ${message}"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            archiveAboveSize="1073741824"
            archiveNumbering="Date"
            maxArchiveFiles="5" />

    <!-- Consola (solo para depuración en desarrollo) -->
    <target xsi:type="Console"
            name="consoleLog"
            layout="${longdate} | ${level:uppercase=true} | ${message}" />

    <!-- Envío de correo automático al archivarse -->
    <target xsi:type="Mail"
            name="mailOnArchive"
            smtpServer="${appsetting:HostRemitente}"
            from="${appsetting:CorreoRemitente}"
            to="${appsetting:CorreoDestinatario}"
            cc="${appsetting:CorreoDestinatarioC}"
            subject="Archivo de log archivado"
            body="Se ha archivado el log ${logger:shortName=true} por superar 20MB. Se adjunta el archivo."
            encoding="utf-8"
            addNewLines="true"
            attachment="${basedir}/Log/Log_${logger:shortName=true}.log" />
  </targets>

  <rules>
    <!-- Logs de aplicaciones -->
    <logger name="AppLogger.*" minlevel="Info" writeTo="appLog,mailOnArchive" />

    <!-- Auditoría central -->
    <logger name="AuditLogger" minlevel="Warn" writeTo="auditLog,consoleLog" />
  </rules>
</nlog>